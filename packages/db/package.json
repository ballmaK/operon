{
  "name": "@operon/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/test-fixtures.d.ts",
      "import": "./dist/test-fixtures.js"
    }
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/migrations','dist/migrations',{recursive:true})\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@operon/shared-types": "workspace:*",
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
